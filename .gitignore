# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# imagens-fonte dos cortes (PNGs originais ~2,8MB cada na raiz de public/).
# O app usa os WebP convertidos em public/cortes/. Remova esta linha se quiser
# versionar os PNGs originais.
/public/*.png
# ...mas versiona a imagem de Open Graph (preview ao compartilhar).
!/public/og.png
# ...e o ícone para iOS (apple-touch-icon).
!/public/apple-touch-icon.png
