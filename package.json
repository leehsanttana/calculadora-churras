{
  "name": "calculadora-churras",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "preview": "next build && wrangler pages dev ./out",
    "lint": "eslint",
    "test": "vitest run",
    "db:migrate": "wrangler d1 migrations apply sonochurras-salas --remote",
    "db:migrate:local": "wrangler d1 migrations apply sonochurras-salas --local",
    "db:tables": "wrangler d1 execute sonochurras-salas --remote --command \"SELECT name FROM sqlite_master WHERE type='table';\""
  },
  "dependencies": {
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260613.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8",
    "wrangler": "^4.100.0"
  }
}
